# Copy this file to .env and fill in values. Never commit .env.

# PostgreSQL (course / team database — get values from your instructor or team)
DB_HOST=csce-315-db.engr.tamu.edu
DB_USER=team_42
DB_NAME=team_42_db
DB_PASSWORD=boba69
# DB_PORT=5432   # optional (defaults to 5432 in code)
# DB_PORT=5432

# Same OAuth 2.0 Web client ID as VITE_GOOGLE_CLIENT_ID (used to verify Google ID tokens server-side)
GOOGLE_CLIENT_ID=

# Secret for signing customer kiosk session JWTs (use a long random string; never commit real values)
AUTH_JWT_SECRET=
# Optional session lifetime (default 7d)
# AUTH_JWT_EXPIRES_IN=7d

# Google Cloud Translation API (customer kiosk)
GOOGLE_TRANSLATE_API_KEY=

# Google AI Studio / Gemini (customer chat assistant)
GEMINI_API_KEY=

# Server (Render and many hosts set PORT automatically)
# PORT=3000
