# Copy this file to .env and fill in values. Never commit .env.

# PostgreSQL (course / team database — get values from your instructor or team)
DB_HOST=
DB_USER=
DB_NAME=
DB_PASSWORD=
# DB_PORT=5432

# Google Cloud Translation API (customer kiosk)
GOOGLE_TRANSLATE_API_KEY=

# Google AI Studio / Gemini (customer chat assistant)
GEMINI_API_KEY=

# Server (Render and many hosts set PORT automatically)
# PORT=3000
